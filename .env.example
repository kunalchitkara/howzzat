# Howzzat — consolidated environment template
# Copy sections to:
#   packages/db/.env          (Prisma CLI — local SQLite)
#   apps/web/.env.local       (Next.js web + API)

# ─── Database ────────────────────────────────────────────────────────────────
# Local dev (Prisma CLI from packages/db):
#   DATABASE_URL="file:./dev.db"
# Local dev (Next.js from apps/web):
#   DATABASE_URL="file:../../packages/db/prisma/dev.db"
# Production (Turso libSQL):
#   DATABASE_URL="libsql://howzzat-prod-….turso.io"
DATABASE_URL="file:../../packages/db/prisma/dev.db"
# DATABASE_AUTH_TOKEN=   # required when DATABASE_URL starts with libsql://

# ─── Web app ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3005"

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_IOS_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=

# Email OTP (Resend)
RESEND_API_KEY=
EMAIL_FROM="Howzzat <hello@howzzat.uk>"
# DEV_EMAIL_BYPASS_EMAIL="dev@local.club"
# DEV_EMAIL_BYPASS_CODE="123456"

# SMS OTP (Twilio Verify) — optional
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
# DEV_SMS_BYPASS_PHONE="+447977036943"
# DEV_SMS_BYPASS_CODE="123456"

# Platform admin — POST /api/v1/admin/coupons (header X-Admin-Secret)
COUPON_ADMIN_SECRET=

# Demo reset — POST /api/v1/demo/u9-match, /api/v1/demo/ios-match
# Local: no header. Production: ALLOW_DEMO_RESET=true OR DEMO_RESET_SECRET + X-Demo-Reset-Secret
# ALLOW_DEMO_RESET=
# DEMO_RESET_SECRET=

# Stripe wallet top-ups
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
