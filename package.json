{
  "name": "howzzat",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@howzzat/web",
    "dev:mobile": "turbo run dev --filter=@howzzat/mobile",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:generate": "turbo run db:generate --filter=@howzzat/db",
    "db:push": "turbo run db:push --filter=@howzzat/db",
    "db:studio": "turbo run db:studio --filter=@howzzat/db",
    "cf:dev": "wrangler dev",
    "cf:deploy": "wrangler deploy",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "wrangler": "^4.19.0"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  }
}
