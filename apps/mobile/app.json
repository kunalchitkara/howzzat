{
  "expo": {
    "name": "Howzzat",
    "description": "Cricket Scoring — live ball-by-ball scoring for matches and tournaments.",
    "slug": "howzzat",
    "version": "0.0.1",
    "orientation": "portrait",
    "scheme": "howzzat",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a1628"
    },
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.howzzat.scorer",
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.472584021178-e5e21285ib9rkt58e282fhfr5osne666"
            ]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a1628"
      },
      "package": "com.howzzat.scorer"
    },
    "plugins": ["expo-router"],
    "extra": {
      "apiUrl": "https://app.howzzat.uk",
      "googleWebClientId": "472584021178-rns0n92evlhgap8a92iat5dfmrtm1tmo.apps.googleusercontent.com",
      "googleIosClientId": "472584021178-e5e21285ib9rkt58e282fhfr5osne666.apps.googleusercontent.com",
      "googleAndroidClientId": "472584021178-5gkp9hdb1dm14hrp7fu0p9fsqqdncdjs.apps.googleusercontent.com"
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
