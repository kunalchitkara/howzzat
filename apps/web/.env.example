# Prisma reads this when running Next.js API routes locally
DATABASE_URL="file:../../packages/db/prisma/dev.db"
# Turso production (libsql://… from `turso db show howzzat-prod --url`)
# DATABASE_AUTH_TOKEN=

# Public app URL (OAuth redirects). Use 3005 if 3000 is busy (see README).
NEXT_PUBLIC_APP_URL="http://localhost:3005"

# Google OAuth — Web (client secret stays server-side only)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google OAuth — iOS / Android (public client IDs)
GOOGLE_IOS_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=

# Twilio Verify (SMS OTP) — Live Account SID + Auth Token from console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# Dev only — skip Twilio when trial verification is mis-formatted
# DEV_SMS_BYPASS_PHONE="+447977036943"
# DEV_SMS_BYPASS_CODE="123456"

# Resend (email OTP sign-in)
RESEND_API_KEY=
EMAIL_FROM="Howzzat <hello@howzzat.uk>"
# Dev: use onboarding@resend.dev until howzzat.uk domain is verified in Resend

# Dev only — skip Resend for a fixed inbox (local testing)
# DEV_EMAIL_BYPASS_EMAIL="dev@local.club"
# DEV_EMAIL_BYPASS_CODE="123456"

# Platform admin — create wallet coupon codes (POST /api/v1/admin/coupons)
# Header: X-Admin-Secret: <value>
COUPON_ADMIN_SECRET=

# Stripe (wallet top-ups)
# Local dev: use TEST keys (sk_test_ / pk_test_) — card 4242...
# Production: use LIVE keys (sk_live_ / pk_live_) — see .env.production.local
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=  # stripe listen --forward-to localhost:3005/api/v1/billing/stripe/webhook
