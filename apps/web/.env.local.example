# Copy to apps/web/.env.local and fill in values for local development.
# See also .env.example for the full variable list.

DATABASE_URL="file:../../packages/db/prisma/dev.db"
NEXT_PUBLIC_APP_URL="http://localhost:3005"

# ── Auth (pick one or more) ──────────────────────────────────────────────────

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email + password (works without Resend — use on invite accept page)
# Register at /login → Password tab, or on invite page (default tab).

# Email OTP via Resend (optional locally)
# RESEND_API_KEY=
# EMAIL_FROM="Howzzat <onboarding@resend.dev>"

# Dev bypass for email OTP — no Resend needed for a fixed test inbox
DEV_EMAIL_BYPASS_EMAIL="dev@local.club"
DEV_EMAIL_BYPASS_CODE="123456"

# SMS OTP via Twilio (optional)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_VERIFY_SERVICE_SID=
# DEV_SMS_BYPASS_PHONE="+447977036943"
# DEV_SMS_BYPASS_CODE="123456"

# ── Invites (local dev) ──────────────────────────────────────────────────────
# Tournament invites do NOT send email — after creating an invite on the
# tournament page, copy the invite link shown in the UI and share it manually.
# Accept with Google or email/password (same address as the invite).
