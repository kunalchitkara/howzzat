// SQLite for local dev + Cloudflare D1 in production (same SQL dialect)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Organizations & users ───────────────────────────────────────────────────

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  homeGround  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  teams       Team[]
  memberships OrgMembership[]
  tournaments Tournament[]
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships OrgMembership[]
  invitesSent TournamentInvite[]
  sessions    Session[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model OrgMembership {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  role           OrgRole  @default(COACH)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
}

enum OrgRole {
  OWNER
  MANAGER
  COACH
  SCORER
  VIEWER
}

// ─── Rules profiles (cloneable templates) ────────────────────────────────────

model RulesProfileTemplate {
  id          String   @id @default(cuid())
  builtinId   String?  @unique
  name        String
  description String?
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())

  versions RulesProfileVersion[]
}

model RulesProfileVersion {
  id         String   @id @default(cuid())
  templateId String
  version    Int
  configJson String
  label      String?
  createdAt  DateTime @default(now())

  template           RulesProfileTemplate   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  tournaments        Tournament[]
  tournamentBindings TournamentRulesBinding[]
  ruleChangesFrom    RuleChangeRequest[]    @relation("RuleChangeFrom")
  ruleChangesTo      RuleChangeRequest[]    @relation("RuleChangeTo")
  matches            Match[]                @relation("MatchRulesVersion")

  @@unique([templateId, version])
}

// ─── Tournaments ─────────────────────────────────────────────────────────────

model Tournament {
  id                    String         @id @default(cuid())
  organizationId        String
  name                  String
  slug                  String
  ageGroup              String?
  seasonLabel           String?
  rulesProfileVersionId String
  plan                  TournamentPlan @default(FREE)
  isPublic              Boolean        @default(true)
  startsOn              DateTime?
  endsOn                DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  organization        Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  rulesProfileVersion RulesProfileVersion      @relation(fields: [rulesProfileVersionId], references: [id])
  teams               TournamentTeam[]
  matches             Match[]
  invites             TournamentInvite[]
  rulesBindings       TournamentRulesBinding[]
  ruleChangeRequests  RuleChangeRequest[]

  @@unique([organizationId, slug])
  @@index([slug])
}

enum TournamentPlan {
  FREE
  PRO
}

model TournamentRulesBinding {
  id                    String   @id @default(cuid())
  tournamentId          String
  rulesProfileVersionId String
  effectiveFrom         DateTime @default(now())
  effectiveFromMatchId    String?
  notes                 String?

  tournament          Tournament          @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  rulesProfileVersion RulesProfileVersion @relation(fields: [rulesProfileVersionId], references: [id])

  @@index([tournamentId, effectiveFrom])
}

model RuleChangeRequest {
  id                   String           @id @default(cuid())
  tournamentId         String
  fromVersionId        String
  toVersionId          String
  mode                 RuleChangeMode
  status               RuleChangeStatus @default(PENDING)
  effectiveFromMatchId String?
  requestedByUserId    String?
  appliedAt            DateTime?
  createdAt            DateTime         @default(now())

  tournament  Tournament          @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  fromVersion RulesProfileVersion @relation("RuleChangeFrom", fields: [fromVersionId], references: [id])
  toVersion   RulesProfileVersion @relation("RuleChangeTo", fields: [toVersionId], references: [id])

  @@index([tournamentId, status])
}

enum RuleChangeMode {
  FUTURE_ONLY
  BACKFILL
}

enum RuleChangeStatus {
  PENDING
  APPLIED
  CANCELLED
}

model TournamentInvite {
  id           String    @id @default(cuid())
  tournamentId String
  email        String
  role         OrgRole   @default(COACH)
  teamId       String?
  token        String    @unique
  acceptedAt   DateTime?
  invitedById  String?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  invitedBy  User?      @relation(fields: [invitedById], references: [id])
  team       Team?      @relation(fields: [teamId], references: [id])

  @@index([tournamentId, email])
}

// ─── Teams & players ─────────────────────────────────────────────────────────

model Team {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  slug           String
  homeGround     String?
  ageGroup       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  memberships     TeamMembership[]
  tournamentTeams TournamentTeam[]
  invites         TournamentInvite[]

  @@unique([organizationId, slug])
}

model Player {
  id          String    @id @default(cuid())
  legalName   String
  displayName String?
  dateOfBirth DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  memberships  TeamMembership[]
  matchSquads  MatchSquadPlayer[]
  matchStats   PlayerMatchStats[]
}

model TeamMembership {
  id          String   @id @default(cuid())
  teamId      String
  playerId    String
  shirtNumber Int?
  seasonLabel String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([teamId, playerId, seasonLabel])
  @@index([playerId])
}

model TournamentTeam {
  id           String  @id @default(cuid())
  tournamentId String
  teamId       String
  publicSlug   String?

  tournament  Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  team        Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  homeMatches Match[]    @relation("HomeTeam")
  awayMatches Match[]    @relation("AwayTeam")

  @@unique([tournamentId, teamId])
  @@unique([tournamentId, publicSlug])
}

// ─── Matches & ball-by-ball ──────────────────────────────────────────────────

model Match {
  id              String      @id @default(cuid())
  tournamentId    String
  homeTeamId      String
  awayTeamId      String
  matchNumber     Int?
  scheduledAt     DateTime?
  venue           String?
  playersPerSide  Int         @default(8)
  status          MatchStatus @default(SCHEDULED)
  isOfficial      Boolean     @default(true)
  resultSummary   String?
  homeScore       Int?
  awayScore       Int?
  winningTeamId   String?
  marginText      String?
  rulesVersionId  String?
  publicSlug      String?
  tossWinnerId         String?
  electedTo            String?
  tossCallerPlayerId   String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  tournament   Tournament          @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  homeTeam     TournamentTeam      @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam     TournamentTeam      @relation("AwayTeam", fields: [awayTeamId], references: [id])
  rulesVersion RulesProfileVersion? @relation("MatchRulesVersion", fields: [rulesVersionId], references: [id])
  innings      Innings[]
  squad        MatchSquadPlayer[]
  playerStats  PlayerMatchStats[]

  @@unique([tournamentId, publicSlug])
  @@index([tournamentId, scheduledAt])
  @@index([tournamentId, matchNumber])
}

enum MatchStatus {
  SCHEDULED
  LIVE
  COMPLETED
  ABANDONED
  WALKOVER
}

model MatchSquadPlayer {
  id       String  @id @default(cuid())
  matchId  String
  playerId String
  teamId   String
  role     String  @default("player")

  match  Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([matchId, playerId])
  @@index([matchId, teamId])
}

model Innings {
  id             String @id @default(cuid())
  matchId        String
  battingTeamId  String
  inningsNumber  Int
  totalRuns      Int?
  wickets        Int?
  batRuns        Int?
  netRuns        Int?
  oversBowled    Float?
  rulesVersionId String

  match      Match      @relation(fields: [matchId], references: [id], onDelete: Cascade)
  deliveries Delivery[]

  @@unique([matchId, inningsNumber])
}

model Delivery {
  id                 String   @id @default(cuid())
  inningsId          String
  sequence           Int
  overNumber         Int
  ballInOver         Int
  isLegalBall        Boolean  @default(true)
  runsOffBat         Int      @default(0)
  extrasType         String?
  extrasRuns         Int      @default(0)
  extrasRunsType     String?
  wicketType         String?
  strikerId          String
  nonStrikerId       String
  bowlerId           String
  fielderId          String?
  dismissedBatsmanId String?
  rulesVersionId     String
  createdAt          DateTime @default(now())

  innings Innings @relation(fields: [inningsId], references: [id], onDelete: Cascade)

  @@unique([inningsId, sequence])
  @@index([inningsId, sequence])
}

model PlayerMatchStats {
  id           String @id @default(cuid())
  matchId      String
  playerId     String
  teamId       String
  batRuns      Int    @default(0)
  wicketsLost  Int    @default(0)
  netRuns      Int    @default(0)
  ballsFaced   Int    @default(0)
  fours        Int    @default(0)
  sixes        Int    @default(0)
  oversBowled  Float  @default(0)
  runsConceded Int    @default(0)
  wicketsTaken Int    @default(0)
  wides        Int    @default(0)
  noBalls      Int    @default(0)
  dotBalls     Int    @default(0)
  catches      Int    @default(0)
  runOuts      Int    @default(0)

  match  Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([matchId, playerId])
  @@index([matchId])
  @@index([playerId])
}
