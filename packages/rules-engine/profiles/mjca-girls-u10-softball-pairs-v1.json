{
  "id": "mjca-girls-u10-softball-pairs-v1",
  "name": "MJCA Girls U10 Softball Pairs",
  "description": "Girls U10 softball pairs: 8 players (up to 10), 16 overs, incrediball, plastic bats permitted.",
  "version": 1,
  "format": "pairs_single_innings",
  "playersPerSide": { "min": 8, "max": 10, "default": 8 },
  "oversPerInnings": { "formula": "2 * playersPerSide" },
  "pairOvers": 4,
  "startingScore": 200,
  "wicketPenalty": 5,
  "scoring": {
    "runsOffBat": { "min": 0, "max": 6 },
    "wide": {
      "default": { "runs": 2, "rebowl": false, "creditToBatsman": false },
      "lastOver": { "runs": 1, "rebowl": true, "maxExtraBalls": 3, "creditToBatsman": false }
    },
    "noBall": {
      "default": { "runs": 2, "rebowl": false, "creditToBatsman": false },
      "lastOver": { "runs": 1, "rebowl": true, "maxExtraBalls": 3, "creditToBatsman": false }
    },
    "bye": { "creditToBatsman": false, "enterTotalRuns": true },
    "legBye": { "creditToBatsman": false, "enterTotalRuns": true }
  },
  "dismissals": {
    "bowlerCredits": ["bowled", "caught", "stumped", "lbw", "hit_wicket"],
    "fielderCredits": ["caught", "run_out"],
    "runOutNoBowlerWicket": true,
    "pairContinuesAfterWicket": true,
    "rotateStrikeAfterWicket": true
  },
  "display": {
    "netRunsFormula": "batRuns - wicketPenalty * wickets",
    "showStartingScoreInTotal": true,
    "economyGoodThreshold": 4.0,
    "economyBadThreshold": 7.0
  },
  "league": {
    "prefix": "mjca",
    "sourceUrl": "https://mjcacricket.org/mjca-rules/competition-rules/girls-outdoor-rules/",
    "ageGroup": "U10",
    "competition": "MJCA Girls U10 Softball League",
    "ballType": "incrediball",
    "pitchYards": 16,
    "playersNote": "Plastic bats permitted. 20 overs if 10 per side agreed.",
    "tunable": ["playersPerSide", "pairOvers", "startingScore", "wicketPenalty", "wide", "noBall", "totalOvers"],
    "pendingEngine": ["injury_substitute_pairs", "bowler_quota"]
  }
}
